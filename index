var mtype='',mpid='';
function openModal(type,pid){
  mtype=type;mpid=pid||'';
  var bg=document.createElement('div');bg.className='mbg';bg.id='mbg';
  bg.onclick=function(e){if(e.target===bg)closeModal();};
  var inner=type==='pl'?
    '<h2>Nova playlist</h2><label>Nome</label><input id="mn" placeholder="Ex: Viagem escola" autocomplete="off"><div class="mbtns"><button class="mcancel" onclick="closeModal()">Cancelar</button><button class="msave" onclick="savePL()">Criar</button></div>':
    '<h2>Adicionar música</h2><label>Título</label><input id="mt" placeholder="Ex: Frozen - Let It Go" autocomplete="off"><label>Link YouTube</label><input id="mu" type="url" placeholder="https://www.youtube.com/watch?v=..." autocomplete="off"><div class="mbtns"><button class="mcancel" onclick="closeModal()">Cancelar</button><button class="msave" onclick="saveT()">Adicionar</button></div>';
  bg.innerHTML='<div class="modal">'+inner+'</div>';
  document.body.appendChild(bg);
  setTimeout(function(){var f=bg.querySelector('input');if(f)f.focus();},150);
}
function closeModal(){var o=document.getElementById('mbg');if(o)o.remove();}
function savePL(){
  var n=document.getElementById('mn').value.trim();
  if(!n){toast('Dá um nome à playlist');return;}
  S.pls.push({id:uid(),name:n,tracks:[]});save();closeModal();render();
}
function saveT(){
  var t=document.getElementById('mt').value.trim();
  var u=document.getElementById('mu').value.trim();
  if(!t||!u){toast('Preenche o título e o link');return;}
  if(!getvid(u)){toast('Link YouTube inválido');return;}
  var pl=S.pls.find(function(p){return p.id===mpid;});
  if(!pl)return;
  pl.tracks.push({t:t,u:u});save();closeModal();render();toast('Música adicionada!');
}
