<script>
var S={pls:[],cur:null,idx:0,on:false,yt:null,ytok:false,tmr:null,shuf:false};
try{var sv=localStorage.getItem('sp4');if(sv)S.pls=JSON.parse(sv);}catch(e){}
if(!S.pls.length){
  S.pls=[
    {id:'x1',name:'Viagem escola',tracks:[{t:'Frozen - Let It Go',u:'https://www.youtube.com/watch?v=L0MK7qz13bU'},{t:'Encanto - Surface Pressure',u:'https://www.youtube.com/watch?v=tBMPASEMJUA'}]},
    {id:'x2',name:'Noite calma',tracks:[{t:'Relaxing Music for Kids',u:'https://www.youtube.com/watch?v=2OEL4P1Rz04'}]}
  ];save();
}
function save(){try{localStorage.setItem('sp4',JSON.stringify(S.pls));}catch(e){}}
function uid(){return 'p'+Date.now();}
function getvid(u){try{var x=new URL(u);if(x.hostname.includes('youtu.be'))return x.pathname.slice(1);return x.searchParams.get('v');}catch(e){return null;}}
function esc(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
function toast(m){var t=document.getElementById('toast');t.textContent=m;t.classList.add('show');setTimeout(function(){t.classList.remove('show');},2800);}

window.onYouTubeIframeAPIReady=function(){
  S.ytok=true;
  S.yt=new YT.Player('ytp',{height:'1',width:'1',
    playerVars:{autoplay:1,controls:0,rel:0,playsinline:1},
    events:{onStateChange:function(e){
      if(e.data===1){S.on=true;startP();render();}
      if(e.data===2){S.on=false;stopP();render();}
      if(e.data===0)nextT();
    }}
  });
};

var shuffleOrder=[];
function buildShuffle(len){
  shuffleOrder=[];for(var i=0;i<len;i++)shuffleOrder.push(i);
  for(var i=shuffleOrder.length-1;i>0;i--){var j=Math.floor(Math.random()*(i+1));var tmp=shuffleOrder[i];shuffleOrder[i]=shuffleOrder[j];shuffleOrder[j]=tmp;}
}

function playT(pid,i){
  var pl=S.pls.find(function(p){return p.id===pid;});
  if(!pl||!pl.tracks[i])return;
  S.cur=pid;S.idx=i;
  var v=getvid(pl.tracks[i].u);
  if(!v){toast('Link YouTube inválido');return;}
  if(S.ytok&&S.yt&&S.yt.loadVideoById){S.yt.loadVideoById(v);S.on=true;}
  else{setTimeout(function(){playT(pid,i);},1500);}
  render();
}
function playPL(pid){
  var pl=S.pls.find(function(p){return p.id===pid;});
  if(!pl||!pl.tracks.length){toast('Adiciona músicas primeiro');return;}
  if(S.shuf){buildShuffle(pl.tracks.length);playT(pid,shuffleOrder[0]);}
  else{playT(pid,0);}
}
function nextT(){
  var pl=S.pls.find(function(p){return p.id===S.cur;});
  if(!pl)return;
  if(S.shuf){
    var si=shuffleOrder.indexOf(S.idx);
    if(si+1<shuffleOrder.length)playT(S.cur,shuffleOrder[si+1]);
    else{S.on=false;stopP();render();}
  } else {
    if(S.idx+1<pl.tracks.length)playT(S.cur,S.idx+1);
    else{S.on=false;stopP();render();}
  }
}
function prevT(){
  if(S.shuf){
    var si=shuffleOrder.indexOf(S.idx);
    if(si>0)playT(S.cur,shuffleOrder[si-1]);
  } else {
    if(S.idx>0)playT(S.cur,S.idx-1);
  }
}
function togPlay(){if(!S.yt||!S.cur)return;if(S.on)S.yt.pauseVideo();else S.yt.playVideo();}
function togShuf(){S.shuf=!S.shuf;render();toast(S.shuf?'Ordem aleatória ativada':'Ordem normal ativada');}
function startP(){
  stopP();
  S.tmr=setInterval(function(){
    if(S.yt&&S.yt.getDuration){
      var d=S.yt.getDuration(),c=S.yt.getCurrentTime();
      var p=d>0?Math.round(c/d*100):0;
      var el=document.getElementById('fill');if(el)el.style.width=p+'%';
    }
  },1000);
}
function stopP(){if(S.tmr){clearInterval(S.tmr);S.tmr=null;}}

function genShareCode(pl){return btoa(unescape(encodeURIComponent(JSON.stringify({n:pl.name,t:pl.tracks}))));}
function getShareUrl(pl){return window.location.href.split('?')[0]+'?import='+genShareCode(pl);}

function checkImportUrl(){
  var p=new URLSearchParams(window.location.search);
  var code=p.get('import');
  if(code){
    try{
      var d=JSON.parse(decodeURIComponent(escape(atob(code))));
      var exists=S.pls.find(function(p){return p.name===d.n;});
      if(!exists){S.pls.push({id:uid(),name:d.n,tracks:d.t});save();toast('Playlist "'+d.n+'" importada!');}
      else{toast('Esta playlist já existe');}
      history.replaceState({},'',window.location.pathname);
    }catch(e){}
  }
}

function openShare(pid){
  var pl=S.pls.find(function(p){return p.id===pid;});
  if(!pl)return;
  var url=getShareUrl(pl);
  var bg=document.createElement('div');bg.className='share-modal-bg';bg.id='share-bg';
  bg.onclick=function(e){if(e.target===bg)bg.remove();};
  bg.innerHTML='<div class="share-modal">'+
    '<h3>Partilhar "'+esc(pl.name)+'"</h3>'+
    '<p>Envia este link para outra mãe. Ao abrir, a playlist é importada automaticamente.</p>'+
    '<div class="share-link-box">'+
      '<span class="share-link-text" id="share-url">'+esc(url)+'</span>'+
      '<button class="share-copy-btn" onclick="copyShareUrl(\''+esc(url)+'\')">Copiar</button>'+
    '</div>'+
    '<button class="share-close" onclick="document.getElementById(\'share-bg\').remove()">Fechar</button>'+
  '</div>';
  document.body.appendChild(bg);
}
function copyShareUrl(url){
  if(navigator.clipboard)navigator.clipboard.writeText(url).then(function(){toast('Link copiado!');});
  else{var ta=document.createElement('textarea');ta.value=url;document.body.appendChild(ta);ta.select();document.execCommand('copy');document.body.removeChild(ta);toast('Link copiado!');}
}

function importCode(code){
  code=code.trim();
  if(code.startsWith('http')){
    try{var u=new URL(code);code=u.searchParams.get('import')||'';}catch(e){}
  }
  try{
    var d=JSON.parse(decodeURIComponent(escape(atob(code))));
    S.pls.push({id:uid(),name:d.n,tracks:d.t});save();
    toast('Playlist importada!');tab('mine');render();
  }catch(e){toast('Link ou código inválido');}
}

function confirmDel(msg,cb){
  var bg=document.createElement('div');bg.className='confirm-bg';bg.id='confirm-bg';
  bg.innerHTML='<div class="confirm-box">'+
    '<h3>Tens a certeza?</h3>'+
    '<p>'+msg+'</p>'+
    '<div class="confirm-btns">'+
      '<button class="confirm-cancel" onclick="document.getElementById(\'confirm-bg\').remove()">Cancelar</button>'+
      '<button class="confirm-ok" id="confirm-ok-btn">Apagar</button>'+
    '</div></div>';
  document.body.appendChild(bg);
  document.getElementById('confirm-ok-btn').onclick=function(){bg.remove();cb();};
}

function delPL(pid){
  var pl=S.pls.find(function(p){return p.id===pid;});
  if(!pl)return;
  confirmDel('Vais apagar a playlist "'+pl.name+'" e todas as suas músicas.',function(){
    S.pls=S.pls.filter(function(p){return p.id!==pid;});
    if(S.cur===pid){S.cur=null;S.on=false;if(S.yt&&S.yt.stopVideo)S.yt.stopVideo();}
    save();render();
  });
}
function delT(pid,i){
  var pl=S.pls.find(function(p){return p.id===pid;});
  if(!pl)return;
  confirmDel('Vais remover "'+pl.tracks[i].t+'" desta playlist.',function(){
    pl.tracks.splice(i,1);save();render();
  });
}

var dragSrc=null,dragPid=null;
function onDragStart(e,pid,i){dragSrc=i;dragPid=pid;e.dataTransfer.effectAllowed='move';}
function onDragOver(e,pid,i){e.preventDefault();e.dataTransfer.dropEffect='move';}
function onDrop(e,pid,i){
  e.preventDefault();
  if(dragPid!==pid||dragSrc===i)return;
  var pl=S.pls.find(function(p){return p.id===pid;});
  if(!pl)return;
  var moved=pl.tracks.splice(dragSrc,1)[0];
  pl.tracks.splice(i,0,moved);
  if(S.cur===pid){S.idx=i;}
  save();render();
}

var ctab='mine';
function tab(t){
  ctab=t;
  ['mine','import','about'].forEach(function(x){
    var el=document.getElementById('t-'+x);
    if(el)el.className='tab'+(x===t?' on':'');
  });
  render();
}

function render(){
  var b=document.getElementById('body');
  if(ctab==='mine')b.innerHTML=rMine();
  else if(ctab==='import')b.innerHTML=rImport();
  else b.innerHTML=rAbout();
}

function rMine(){
  var h='';
  var pl=S.pls.find(function(p){return p.id===S.cur;});
  if(pl&&S.on){
    var tr=pl.tracks[S.idx];
    h+='<div class="np"><div class="nplbl">A tocar agora</div><div class="nptitle">'+esc(tr.t)+'</div>'+
      '<div class="npc">'+
        '<button class="cb" onclick="prevT()"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M6 6h2v12H6zm3.5 6 8.5 6V6z"/></svg></button>'+
        '<button class="cb main" onclick="togPlay()"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg></button>'+
        '<button class="cb" onclick="nextT()"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M6 18l8.5-6L6 6v12zM16 6h2v12h-2z"/></svg></button>'+
        '<div class="bar"><div class="fill" id="fill"></div></div>'+
        '<button class="cb'+(S.shuf?' main':'')+'" onclick="togShuf()" title="Aleatório"><svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M10.59 9.17L5.41 4 4 5.41l5.17 5.17 1.42-1.41zM14.5 4l2.04 2.04L4 18.59 5.41 20 17.96 7.46 20 9.5V4h-5.5zm.33 9.41l-1.41 1.41 3.13 3.13L14.5 20H20v-5.5l-2.04 2.04-3.13-3.13z"/></svg></button>'+
      '</div></div>';
  }
  if(!S.pls.length)return h+'<div class="empty"><svg width="48" height="48" viewBox="0 0 24 24" fill="#dda8a2" style="margin-bottom:16px"><path d="M12 3v10.55A4 4 0 1 0 14 17V7h4V3h-6z"/></svg><div class="etitle">Sem playlists ainda</div><div class="esub">Cria a tua primeira playlist<br>com músicas do YouTube.</div></div>';
  S.pls.forEach(function(p){
    var isOn=p.id===S.cur;
    h+='<div class="card'+(isOn?' on':'')+'">'+
      '<div class="pl-row">'+
        '<div class="pl-ic"><svg viewBox="0 0 24 24"><path d="M12 3v10.55A4 4 0 1 0 14 17V7h4V3h-6z"/></svg></div>'+
        '<div class="pl-info"><div class="pl-name">'+esc(p.name)+'</div><div class="pl-sub">'+p.tracks.length+' música'+(p.tracks.length!==1?'s':'')+'</div></div>'+
        '<div class="pl-btns">'+
          '<button class="ib" onclick="openModal(\'t\',\''+p.id+'\')" title="Adicionar música"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/></svg></button>'+
          '<button class="ib" onclick="delPL(\''+p.id+'\')" title="Apagar playlist"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"/></svg></button>'+
        '</div>'+
      '</div>'+
      (p.tracks.length?'<div class="tlist" id="tlist-'+p.id+'">'+p.tracks.map(function(tr,i){
        var isCur=S.cur===p.id&&S.idx===i&&S.on;
        return '<div class="trow" draggable="true" ondragstart="onDragStart(event,\''+p.id+'\','+i+')" ondragover="onDragOver(event,\''+p.id+'\','+i+')" ondrop="onDrop(event,\''+p.id+'\','+i+')">'+
          '<span class="drag-handle"><svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" opacity=".3"><path d="M11 18c0 1.1-.9 2-2 2s-2-.9-2-2 .9-2 2-2 2 .9 2 2zm-2-8c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm0-6c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm6 4c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zm0 2c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm0 6c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z"/></svg></span>'+
          '<span class="tnum">'+(isCur?'&#9654;':(i+1))+'</span>'+
          '<span class="ttitle'+(isCur?' now':'')+'" onclick="playT(\''+p.id+'\','+i+')">'+esc(tr.t)+'</span>'+
          '<button class="tdel" onclick="delT(\''+p.id+'\','+i+')">&times;</button>'+
        '</div>';
      }).join('')+'</div>':'')+
      '<div class="actions">'+
        '<button class="pbtn'+(isOn&&S.on?' playing':'')+'" onclick="playPL(\''+p.id+'\')">'+
          '<svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="'+(isOn&&S.on?'M6 19h4V5H6v14zm8-14v14h4V5h-4z':'M8 5v14l11-7z')+'"/></svg>'+
          (isOn&&S.on?'A tocar':'Iniciar')+
        '</button>'+
        '<button class="shuf-btn'+(S.shuf?' on':'')+'" onclick="togShuf()">'+
          '<svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M10.59 9.17L5.41 4 4 5.41l5.17 5.17 1.42-1.41zM14.5 4l2.04 2.04L4 18.59 5.41 20 17.96 7.46 20 9.5V4h-5.5zm.33 9.41l-1.41 1.41 3.13 3.13L14.5 20H20v-5.5l-2.04 2.04-3.13-3.13z"/></svg>'+
          (S.shuf?'Aleatório':'Ordem')+
        '</button>'+
        '<button class="sbtn" onclick="openShare(\''+p.id+'\')">Partilhar</button>'+
      '</div>'+
    '</div>';
  });
  return h;
}

